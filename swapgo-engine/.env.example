# .env.example — 실제 .env 파일로 복사 후 값을 채우세요.
# 절대로 .env 파일을 Git 에 커밋하지 마세요.

# ── 필수 ─────────────────────────────────────────────────────
# 백엔드 첫 부팅 콘솔에 한 번 표시되는 raw 봇 키를 그대로 붙여넣으세요.
#   예) [bot] 기본 봇 API 키 ... X-Bot-Key: zX8s...t4Pq
# (구버전 BOT_KEY 도 호환되지만 신규 설정은 SWAPGO_BOT_KEY 를 쓰세요.)
SWAPGO_BOT_KEY=
SWAPGO_BASE_URL=http://localhost:8000

# ── 풀 ID ─────────────────────────────────────────────────────
POOL_ID=1        # BTC 풀
ETH_POOL_ID=2    # ETH 풀 (8피처 중 Ret_eth·Volume_eth 계산에 사용)

# ── 심볼 ─────────────────────────────────────────────────────
SYMBOLS=["BTC","ETH"]

# ── AI 모델 경로 ─────────────────────────────────────────────
# [시스템 A 전용: 대시보드 신호용 장기 예측]
MODEL_SCALPER_PATH=models/model_scalper.onnx    # 1h  신호  seq_len=10
MODEL_SWING_PATH=models/model_swing.onnx        # 24h 신호  seq_len=60
MODEL_LONGTERM_PATH=models/model_longterm.onnx  # 7d  신호  seq_len=120
# [시스템 B 전용: 직접 거래용 단기 예측]
MODEL_TRADE_PATH=models/model_trade.onnx        # 1분 후    seq_len=30
MODEL_TAG=gru-v1

# ── Scaler (4개 모델 공통) ────────────────────────────────────
SCALER_PATH=models/scaler.pkl

# ── 출력 EMA 평활 ────────────────────────────────────────────
EMA_ALPHA=0.3

# ── 캔들 수집 ────────────────────────────────────────────────
CANDLE_INTERVAL=5m
CANDLE_LIMIT=200

# ════════════════════════════════════════════════════════════
# 시스템 A: 대시보드 신호 봇
# ════════════════════════════════════════════════════════════
INGEST_INTERVAL_SEC=30

# 시스템 A 자동거래 (선택, 기본 OFF)
ENABLE_AUTO_TRADE=false
TRADE_CONFIDENCE_THRESHOLD=0.7
TRADE_AMOUNT_HUMAN=10
TRADE_SLIPPAGE_BPS=100

# WebSocket 보조 ingest (선택)
USE_WEBSOCKET=false

# ════════════════════════════════════════════════════════════
# 시스템 B: 가상 시장 조성 봇 (기본 OFF)
# 거래봇 ON: 백엔드 /swap/execute · /wallet/deposit/mock 가 봇키(X-Bot-Key, scope bot:trade)를
# 받도록 수정됨. 부팅 시 모의 입금으로 자동 충전 후 BotA_Trade(AI)·BotB_Noise 가 매수/매도를 수행.
# ════════════════════════════════════════════════════════════
ENABLE_TRADE_BOTS=true

# BotA_Trade (AI 차익거래 봇)
TRADE_MIN_LOG_RETURN=0.0002   # 거래 트리거 최소 |log_return| (약 0.02%)
TRADE_MIN_CONFIDENCE=0.55     # 거래 트리거 최소 confidence
TRADE_EXECUTE_AMOUNT_HUMAN=5  # 1회 거래 수량
TRADE_EXECUTE_SLIPPAGE_BPS=200
TRADE_COOLDOWN_SEC=5.0        # 연속 거래 최소 대기(초)
TRADE_POLL_INTERVAL_SEC=30.0  # WS 비활성 시 REST 폴링 주기
TRADE_STALE_RETRY=3

# BotB_Noise (랜덤 노이즈 봇)
NOISE_INTERVAL_MIN=3.0        # 최소 대기(초)
NOISE_INTERVAL_MAX=8.0        # 최대 대기(초)
NOISE_AMOUNT_MIN=0.001        # 최소 거래량
NOISE_AMOUNT_MAX=0.05         # 최대 거래량
NOISE_SLIPPAGE_BPS=500

# ════════════════════════════════════════════════════════════
# 시스템 C: LP 봇 (기본 OFF)
# ════════════════════════════════════════════════════════════
ENABLE_LP_BOT=false