# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 환경 변수 설정 파일. 로컬 개발 환경에서 사용됨
.env*.local
.env.development.local
.env.test.local
.env.production.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# npm이나 yarn에서 발생한 오류 로그 파일. 디버깅 목적으로만 사용되며, 커밋할 필요가 없음
npm-debug.log*
yarn-debug.log*
yarn-error.log*
